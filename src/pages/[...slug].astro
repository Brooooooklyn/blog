---
import PostPage from '#components/PostPage.astro'
import { DEFAULT_LANG } from '#consts.ts'
import { getPostsByLang } from '#utils/posts.ts'

const lang = DEFAULT_LANG

export async function getStaticPaths() {
  const posts = await getPostsByLang('en')
  return posts.map((post, index) => {
    const date = post.data.date
    const year = date.getFullYear()
    const month = String(date.getMonth() + 1).padStart(2, '0')
    const day = String(date.getDate()).padStart(2, '0')
    return {
      params: { slug: `${year}/${month}/${day}/${post.data.postname}` },
      props: { post, prev: posts[index + 1] ?? null, next: posts[index - 1] ?? null },
    }
  })
}

const { post, prev, next } = Astro.props
---

<PostPage post={post} prev={prev} next={next} lang={lang} />
