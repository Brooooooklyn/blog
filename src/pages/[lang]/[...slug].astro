---
import PostPage from '#components/PostPage.astro'
import { LANGUAGES, DEFAULT_LANG } from '#consts.ts'
import type { Lang } from '#consts.ts'
import { getPostsByLang } from '#utils/posts.ts'

export async function getStaticPaths() {
  const paths = []
  for (const lang of (Object.keys(LANGUAGES) as Lang[]).filter((l) => l !== DEFAULT_LANG)) {
    const posts = await getPostsByLang(lang)
    for (let index = 0; index < posts.length; index++) {
      const post = posts[index]
      const date = post.data.date
      const year = date.getFullYear()
      const month = String(date.getMonth() + 1).padStart(2, '0')
      const day = String(date.getDate()).padStart(2, '0')
      paths.push({
        params: { lang, slug: `${year}/${month}/${day}/${post.data.postname}` },
        props: { post, prev: posts[index + 1] ?? null, next: posts[index - 1] ?? null },
      })
    }
  }
  return paths
}

const lang = Astro.params.lang as Lang
const { post, prev, next } = Astro.props
---

<PostPage post={post} prev={prev} next={next} lang={lang} />
