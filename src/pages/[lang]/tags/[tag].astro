---
import BaseLayout from '#layouts/BaseLayout.astro'
import PostList from '#components/PostList.astro'
import { UI_STRINGS, LANGUAGES } from '#consts.ts'
import type { Lang } from '#consts.ts'
import { getPostsByLang } from '#utils/posts.ts'

export async function getStaticPaths() {
  const paths = []
  for (const lang of Object.keys(LANGUAGES) as Lang[]) {
    const posts = await getPostsByLang(lang)
    const tags = new Set<string>()
    posts.forEach((post) => post.data.tags?.forEach((tag) => tags.add(tag)))
    for (const tag of tags) {
      paths.push({
        params: { lang, tag },
        props: {
          tag,
          posts: posts.filter((p) => p.data.tags?.includes(tag)),
        },
      })
    }
  }
  return paths
}

const lang = Astro.params.lang as Lang
const t = UI_STRINGS[lang]
const { tag, posts } = Astro.props
---

<BaseLayout title={`${t.taggedWith} "${tag}"`} lang={lang}>
  <div class="mb-10">
    <a href={`/${lang}/`} class="text-sm text-neutral-400 no-underline transition-colors hover:text-neutral-600 dark:text-neutral-500 dark:hover:text-neutral-300">
      &larr; {t.backToAll}
    </a>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
      {tag}
    </h1>
    <p class="mt-1 text-sm text-neutral-400 dark:text-neutral-500">
      {posts.length} {t.postsTagged}
    </p>
  </div>
  <PostList posts={posts} lang={lang} />
</BaseLayout>
