---
import BaseLayout from '#layouts/BaseLayout.astro'
import PostList from '#components/PostList.astro'
import { UI_STRINGS, DEFAULT_LANG } from '#consts.ts'
import { getPostsByLang, langPrefix } from '#utils/posts.ts'

const lang = DEFAULT_LANG
const t = UI_STRINGS[lang]

export async function getStaticPaths() {
  const posts = await getPostsByLang('en')
  const tags = new Set<string>()
  posts.forEach((post) => post.data.tags?.forEach((tag) => tags.add(tag)))
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      tag,
      posts: posts.filter((p) => p.data.tags?.includes(tag)),
    },
  }))
}

const { tag, posts } = Astro.props
---

<BaseLayout title={`${t.taggedWith} "${tag}"`} lang={lang}>
  <div class="mb-10">
    <a href={`${langPrefix(lang)}/`} class="text-sm text-neutral-400 no-underline transition-colors hover:text-neutral-600 dark:text-neutral-500 dark:hover:text-neutral-300">
      &larr; {t.backToAll}
    </a>
    <h1 class="mt-4 text-3xl font-bold tracking-tight text-neutral-900 dark:text-neutral-100">
      {tag}
    </h1>
    <p class="mt-1 text-sm text-neutral-400 dark:text-neutral-500">
      {posts.length} {t.postsTagged}
    </p>
  </div>
  <PostList posts={posts} lang={lang} />
</BaseLayout>
