---
import type { Lang } from '#consts.ts'
import { SITE_TITLE, LANGUAGES, DEFAULT_LANG } from '#consts.ts'
import { langPrefix } from '#utils/posts.ts'
import ThemeToggle from '#components/ThemeToggle.astro'

interface Props {
  lang: Lang
}

const { lang } = Astro.props
const otherLang = lang === 'en' ? 'zh' : 'en'
const currentPath = Astro.url.pathname

// Strip current lang prefix (if any) to get the bare path, then add the other lang prefix
const currentPrefix = langPrefix(lang)
const barePath = currentPrefix ? currentPath.slice(currentPrefix.length) : currentPath
const switchedPath = `${langPrefix(otherLang)}${barePath}`
---

<header class="mb-16 flex items-center justify-between">
  <a href={`${langPrefix(lang)}/`} class="text-xl font-semibold tracking-tight text-neutral-900 no-underline dark:text-neutral-100">
    {SITE_TITLE}
  </a>
  <nav class="flex items-center gap-4">
    <a
      href={switchedPath}
      class="text-sm text-neutral-500 transition-colors hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100"
    >
      {LANGUAGES[otherLang]}
    </a>
    <ThemeToggle />
  </nav>
</header>
