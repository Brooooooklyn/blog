---
import type { Lang } from '#consts.ts'
import { UI_STRINGS, LOCALE_MAP } from '#consts.ts'
import TagBadge from '#components/TagBadge.astro'
import { getPostUrl, getReadingTime } from '#utils/posts.ts'

interface Props {
  posts: Array<{
    id: string
    body?: string
    data: {
      title: string
      date: Date
      postname: string
      tags?: string[]
    }
  }>
  lang: Lang
}

const { posts, lang } = Astro.props
const t = UI_STRINGS[lang]
---

<div class="space-y-10">
  {posts.map((post) => {
    const readingTime = post.body ? getReadingTime(post.body) : 1
    return (
      <article>
        <a href={getPostUrl(post, lang)} class="group block no-underline">
          <h3 class="text-lg font-medium text-neutral-900 transition-colors group-hover:text-neutral-600 dark:text-neutral-100 dark:group-hover:text-neutral-300">
            {post.data.title}
          </h3>
          <div class="mt-1.5 flex items-center gap-2 text-sm text-neutral-400 dark:text-neutral-500">
            <time datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString(LOCALE_MAP[lang], {
                year: 'numeric',
                month: 'long',
                day: 'numeric',
              })}
            </time>
            <span>&middot;</span>
            <span>{readingTime} {t.minRead}</span>
          </div>
        </a>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="mt-2 flex flex-wrap gap-1.5">
            {post.data.tags.map((tag) => (
              <TagBadge tag={tag} lang={lang} />
            ))}
          </div>
        )}
      </article>
    )
  })}
</div>
